# Porta em que a API vai rodar
PORT=3333

# URL do front-end que pode acessar a API
CORS_ORIGIN=http://localhost:5173

# Chave usada para gerar tokens JWT (NUNCA suba o valor real)
JWT_SECRET=dev-secret

# Tipo de repositório (inmemory ou database)
REPOSITORY_IMPL=inmemory

# Ambiente atual
NODE_ENV=development
